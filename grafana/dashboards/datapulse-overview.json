{
  "title": "DataPulse Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "API Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "datapulse_api_requests_total" }]
    },
    {
      "type": "stat",
      "title": "Pipeline Runs",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "datapulse_pipeline_runs_total" }]
    },
    {
      "type": "stat",
      "title": "Pipeline Failures",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "datapulse_pipeline_failures_total" }]
    },
    {
      "type": "stat",
      "title": "Data Quality Failures",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "datapulse_quality_failures_total" }]
    }
  ]
}
