APP_NAME=DataPulse
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./datapulse.db
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AIRFLOW_BASE_URL=
AIRFLOW_MOCK_MODE=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://datapulse:datapulse@localhost:5432/datapulse
